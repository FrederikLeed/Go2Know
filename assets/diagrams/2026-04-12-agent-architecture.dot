digraph agent_architecture {
    rankdir=TB;
    compound=true;
    bgcolor="white";
    pad=0.3;
    splines=true;
    nodesep=0.4;
    ranksep=0.6;

    node [
        shape=box,
        style="rounded,filled",
        fontname="Helvetica",
        fontsize=11,
        fillcolor="#F7F7F7",
        color="#333333",
        penwidth=1.2
    ];
    edge [
        fontname="Helvetica",
        fontsize=10,
        color="#444444",
        penwidth=1.1,
        arrowsize=0.8
    ];

    browser [label="Browser", fillcolor="#EAEAEA"];

    subgraph cluster_host {
        label="Workstation / Docker Host";
        fontname="Helvetica";
        fontsize=12;
        style="rounded,dashed";
        color="#888888";
        margin=16;

        mgr   [label="claude-manager"];
        socket [label="Docker socket\n(manager only)", shape=cylinder, fillcolor="#EAEAEA"];
        proxy [label="Egress proxy\ndeny-by-default\napproval flow", fillcolor="#FFF4E6", color="#C77A1B"];

        subgraph cluster_containers {
            label="Per-project containers";
            fontname="Helvetica";
            fontsize=11;
            style="rounded,filled";
            color="#BBBBBB";
            fillcolor="#FAFAFA";
            margin=12;

            a [label="Project A"];
            b [label="Project B"];
            c [label="Project C"];
        }
    }

    internet [label="Public internet", fillcolor="#EAF5EA", color="#4E8E4E"];
    internal [label="Internal network", fillcolor="#FDECEC", color="#B94A48"];

    browser -> mgr;
    mgr -> socket;
    socket -> a [label="creates", lhead=cluster_containers];

    a -> proxy;
    b -> proxy;
    c -> proxy;

    proxy -> internet [label="approved only"];

    b -> internal [label="no route", ltail=cluster_containers, style=dashed, color="#B94A48", fontcolor="#B94A48", arrowhead=none];
}
